              "raw": "{\n  \"tipoTest\": \"ANSIEDAD\",\n  \"respuestas\": {\n    \"item_1\": 3,\n    \"item_2\": 4,\n    \"item_3\": 2,\n    \"item_4\": 4,\n    \"item_5\": 3,\n    \"item_6\": 2,\n    \"item_7\": 1\n  },\n  \"puntajeTotal\": 45,\n  \"diagnosticoPreliminar\": \"Ansiedad moderada con tendencia hacia lo moderado-alto\"\n}\n"
